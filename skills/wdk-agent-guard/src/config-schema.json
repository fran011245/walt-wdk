{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "dailyLimit": {
      "type": "object",
      "properties": {
        "amount": { "type": "string", "pattern": "^\\d+\\.?\\d*$" },
        "currency": { "enum": ["USDT", "USDC"] }
      }
    },
    "perTransactionLimit": {
      "type": "object",
      "properties": {
        "amount": { "type": "string" },
        "currency": { "type": "string" }
      }
    },
    "requireApproval": {
      "type": "object",
      "properties": {
        "overAmount": { "type": "string" },
        "notifyVia": { "enum": ["telegram", "email", "discord"] },
        "timeout": { "type": "string", "default": "5m" }
      }
    },
    "whitelist": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "address": { "type": "string" },
          "name": { "type": "string" },
          "skipApproval": { "type": "boolean" }
        }
      }
    },
    "blacklist": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
