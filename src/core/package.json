{
  "name": "@walt-wdk/core",
  "version": "1.0.0",
  "description": "Shared WDK client, config and security utilities for WaltWDK skills",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
