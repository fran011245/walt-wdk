    "tronweb": "^5.3.4",
    "@noble/hashes": "^1.7.1"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.6",
    "@vitest/coverage-v8": "^2.1.6"
  },
  "engines": {
    "node": ">=18"
  }
}
