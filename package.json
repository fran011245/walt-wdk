{
  "name": "walt-wdk",
  "version": "1.3.0",
  "description": "OpenClaw Skills Pack for Tether WDK — Galactica WDK Edition",
  "private": true,
  "license": "Apache-2.0",
  "author": "WaltWDK Contributors",
  "homepage": "https://walt-wdk.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/fran011245/walt-wdk.git"
  },
  "type": "module",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "coverage": "npm run coverage --workspaces --if-present"
  },
  "workspaces": [
    "src/core",
    "skills/wdk-wallet",
    "skills/wdk-pay",
    "skills/wdk-agent-guard"
  ],
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.6",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^2.1.6",
    "eslint": "^9.16.0",
    "globals": "^15.13.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.17.0"
  },
  "dependencies": {
    "@tetherto/wdk": "^1.0.0-beta.6",
    "@tetherto/wdk-wallet-evm": "^1.0.0-beta.8",
    "@tetherto/wdk-wallet-tron": "^1.0.0-beta.4"
  },
  "engines": {
    "node": ">=18"
  }
}
